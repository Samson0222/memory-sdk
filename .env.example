# Memory SDK — Environment Variable Reference
# Copy this file to .env and fill in the values for your environment.
# All fields map directly to MemoryConfig in config.py.

# ---------------------------------------------------------------------------
# Execution mode
# ---------------------------------------------------------------------------
# 'local'  — single-user development; user_id scoping is bypassed
# 'server' — production; strict user_id filtering enforced on every call
RUN_MODE=local

# ---------------------------------------------------------------------------
# Storage backends
# ---------------------------------------------------------------------------
# Vector store for the Deep Archive: 'pgvector' | 'qdrant'
VECTOR_DB_TYPE=pgvector

# State store for the Active Substrate: 'postgresql' | 'local_json'
STATE_DB_TYPE=local_json

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Enable dense + sparse (BM25) hybrid search in the archive
HYBRID_SEARCH_ENABLED=true

# ---------------------------------------------------------------------------
# Embedding
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ---------------------------------------------------------------------------
# Thresholds
# ---------------------------------------------------------------------------
# Cosine similarity above which an ingested fact is skipped as a duplicate
DEDUP_SIMILARITY_THRESHOLD=0.95

# importance_score above which the consolidation worker fires immediately
HOT_CONSOLIDATION_THRESHOLD=0.85

# ---------------------------------------------------------------------------
# PostgreSQL (required when VECTOR_DB_TYPE=pgvector or STATE_DB_TYPE=postgresql)
# ---------------------------------------------------------------------------
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/memory_sdk

# ---------------------------------------------------------------------------
# Qdrant (required when VECTOR_DB_TYPE=qdrant)
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=memory_archive

# ---------------------------------------------------------------------------
# Local JSON substrate (used when STATE_DB_TYPE=local_json)
# ---------------------------------------------------------------------------
LOCAL_JSON_DIR=.memory_state
